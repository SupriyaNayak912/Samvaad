<?xml version="1.0" encoding="utf-8"?>
<!-- ColorStateList selector for BottomNavigationView icon tint and text color.
     Active (checked) → Teal   #00BFA5
     Inactive          → Gray  #9CA3AF  -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/nav_active" android:state_checked="true" />
    <item android:color="@color/nav_inactive" />
</selector>
