<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- ─── HEADER ────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_welcome_back"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Good morning,"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:letterSpacing="0.04"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/card_streak"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Daily Streak badge -->
        <com.example.samvaad.ui.components.GlassmorphismContainer
            android:id="@+id/card_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:background="@drawable/card_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tv_user_name">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tv_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="3 Days"
                    android:textColor="@color/status_orange"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.example.samvaad.ui.components.GlassmorphismContainer>

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Supriya"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/card_streak"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome_back" />

        <!-- Dynamic inspirational tagline -->
        <TextView
            android:id="@+id/tv_tagline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Let's build confidence today ✨"
            android:textColor="@color/teal_accent"
            android:textSize="13sp"
            android:fontFamily="sans-serif-light"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/card_streak"
            app:layout_constraintTop_toBottomOf="@id/tv_user_name" />

        <!-- ─── PRIMARY CTA ─────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_tagline">

            <!-- Start New Session (Full) -->
            <com.example.samvaad.ui.components.LlmCustomButton
                android:id="@+id/btn_start_session"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:text="Start New Session"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:elevation="10dp"
                app:backgroundTint="@color/primary_purple"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_media_play"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />

            <!-- Daily Drill (Short) -->
            <com.example.samvaad.ui.components.LlmCustomButton
                android:id="@+id/btn_daily_drill"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:layout_marginStart="8dp"
                android:text="1-Min Drill"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:elevation="10dp"
                app:backgroundTint="@color/status_orange"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_menu_today"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />
        </LinearLayout>

        <!-- ─── INSIGHT CARD ───────────────────────────────────────── -->
        <com.example.samvaad.ui.components.GlassmorphismContainer
            android:id="@+id/card_insight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:elevation="10dp"
            app:layout_constraintTop_toBottomOf="@id/ll_actions">

            <!-- Teal accent bar -->
            <View
                android:id="@+id/bar_insight"
                android:layout_width="3dp"
                android:layout_height="0dp"
                android:background="@color/teal_accent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Interview Readiness Index -->
            <TextView
                android:id="@+id/tv_stability_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="--%"
                android:textColor="@color/primary_purple"
                android:textSize="36sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/bar_insight"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_iri_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Interview Readiness Index ⓘ"
                android:textColor="@color/teal_accent"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                app:layout_constraintStart_toEndOf="@id/bar_insight"
                app:layout_constraintTop_toBottomOf="@id/tv_stability_score" />

            <!-- Dynamic advice string -->
            <TextView
                android:id="@+id/tv_insight_advice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:text="You're doing great! Try a 'Stress Test' scenario today."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/bar_insight"
                app:layout_constraintTop_toBottomOf="@id/tv_stability_score" />

        </com.example.samvaad.ui.components.GlassmorphismContainer>

        <!-- ─── RECOMMENDED SECTION ──────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_recommended_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Recommended for You"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_see_all"
            app:layout_constraintTop_toBottomOf="@id/card_insight" />

        <TextView
            android:id="@+id/tv_see_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="See all →"
            android:textColor="@color/teal_accent"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_insight" />

        <!-- Horizontal Scenarios RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recommended"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tv_recommended_label" />

        <!-- ─── PROGRESS SECTION ─────────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_progress_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Your Progress"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_recommended" />

        <!-- ─── LEVEL ROADMAP SECTION ─── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_roadmap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tv_progress_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Sessions Completed Card -->
        <com.example.samvaad.ui.components.GlassmorphismContainer
            android:id="@+id/card_sessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_background"
            android:padding="18dp"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/rv_roadmap">

            <View
                android:id="@+id/icon_sessions"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/glow_ring"
                android:backgroundTint="@color/teal_accent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_metrics_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Total Practice Time"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/tv_growth_trend"
                app:layout_constraintStart_toEndOf="@id/icon_sessions"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_metrics_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--h --m"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/tv_metrics_label"
                app:layout_constraintTop_toBottomOf="@id/tv_metrics_label" />

            <TextView
                android:id="@+id/tv_growth_trend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--% Growth"
                android:textColor="@color/status_green"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="end"
                app:layout_constraintBottom_toTopOf="@id/tv_growth_basis"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tv_growth_basis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(vs last 3 sessions)"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:gravity="end"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_growth_trend" />

        </com.example.samvaad.ui.components.GlassmorphismContainer>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>