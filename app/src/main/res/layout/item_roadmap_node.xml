<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="32dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center_horizontal">

        <!-- Circular Map Pin -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_node"
            android:layout_width="66dp"
            android:layout_height="66dp"
            app:cardCornerRadius="33dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#2A2A2A">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                
                <View
                    android:id="@+id/view_glow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/glow_ring"
                    android:alpha="0" />

                <ImageView
                    android:id="@+id/iv_node_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/btn_star_big_on"
                    android:tint="@color/text_secondary" />
                    
                <ImageView
                    android:id="@+id/iv_node_lock"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_secure"
                    android:tint="@color/status_red"
                    android:visibility="gone" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Node Label -->
        <TextView
            android:id="@+id/tv_node_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Level Name"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />
            
        <TextView
            android:id="@+id/tv_node_level"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
</FrameLayout>
