<?xml version="1.0" encoding="utf-8"?>
<com.example.samvaad.ui.components.GlassmorphismContainer xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/card_background"
    android:padding="20dp"
    app:elevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Question Title -->
        <TextView
            android:id="@+id/tv_qa_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Question text goes here?"
            android:textColor="@color/teal_accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            android:background="@color/primary_purple" />

        <!-- User Answer Summary -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="YOUR RESPONSE"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tv_qa_user_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Summary of what the candidate said."
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <!-- Coach's better approach -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="COACH'S RECOMMENDATION"
            android:textColor="@color/status_orange"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tv_qa_better_approach"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="How this could have been improved using STAR or more depth."
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>
</com.example.samvaad.ui.components.GlassmorphismContainer>
