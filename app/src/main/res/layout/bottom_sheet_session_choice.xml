<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/main_gradient_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Start New Session"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="How would you like to practice today?"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <!-- SMART SESSION OPTION -->
    <com.example.samvaad.ui.components.GlassmorphismContainer
        android:id="@+id/card_smart_session"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/card_background"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_progress_label">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/glow_ring"
                android:backgroundTint="@color/primary_purple"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/primary_purple" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smart Session ✨"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="AI generates custom questions tailored to your exact role and company."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </com.example.samvaad.ui.components.GlassmorphismContainer>

    <!-- SESSION VAULT OPTION -->
    <com.example.samvaad.ui.components.GlassmorphismContainer
        android:id="@+id/card_vault_session"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_background"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/glow_ring"
                android:backgroundTint="@color/teal_accent"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="@color/teal_accent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Session Vault"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Pick from dozens of community-verified pre-made interview scenarios."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </com.example.samvaad.ui.components.GlassmorphismContainer>

</LinearLayout>
