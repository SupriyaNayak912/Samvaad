<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg">

    <!-- Placeholder overlay for audio-only (black screen) -->
    <TextView
        android:id="@+id/tv_audio_only_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1D36"
        android:gravity="center"
        android:text="Audio Only\nVideo Disabled"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:visibility="gone"
        android:elevation="1dp" />

    <!-- ══════════════════════════════════════════════════════════
         CHAOS FLASH OVERLAY (Hidden by default)
         ══════════════════════════════════════════════════════════ -->
    <View
        android:id="@+id/view_chaos_flash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80FF0000"
        android:alpha="0"
        android:clickable="false"
        android:elevation="90dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ══════════════════════════════════════════════════════════
         TELEMETRY BORDER OVERLAY — sits above everything, no-click
         Animated to orange (fast WPM) or blue (mumbling) at runtime
         ══════════════════════════════════════════════════════════ -->
    <View
        android:id="@+id/view_telemetry_border"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:alpha="0"
        android:clickable="false"
        android:elevation="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ══════════════════════════════════════════════════════════
         TEAL TIMER BAR — very top, 5dp tall
         ══════════════════════════════════════════════════════════ -->
    <ProgressBar
        android:id="@+id/pb_question_timer"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:max="100"
        android:progress="100"
        android:progressDrawable="@drawable/progress_teal"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ══════════════════════════════════════════════════════════
         VIEW FLIPPER — Phase 1 (Pre-Flight) ↔ Phase 2 (Simulator)
         ══════════════════════════════════════════════════════════ -->
    <ViewFlipper
        android:id="@+id/view_flipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- ─────────────────────────────────────────────────────
             PHASE 1: PRE-FLIGHT SETUP
             ───────────────────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_preflight"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="40dp">

                <!-- Back button -->
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:padding="8dp"
                    app:tint="@color/text_secondary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Scenario name chip -->
                <TextView
                    android:id="@+id/tv_scenario_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip_unselected_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="5dp"
                    android:text="HR · Beginner"
                    android:textColor="@color/teal_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btn_back"
                    app:layout_constraintBottom_toBottomOf="@id/btn_back" />

                <!-- Title -->
                <TextView
                    android:id="@+id/tv_preflight_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Pre-Flight Check"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_back" />

                <TextView
                    android:id="@+id/tv_preflight_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Configure your session before starting"
                    android:textColor="@color/teal_accent"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_preflight_title" />

                <!-- Placeholder for camera preview Mirror in Pre-Flight (160dp down) -->
                <View
                    android:id="@+id/view_camera_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_preflight_subtitle" />

                <!-- ── SETTINGS AND CHECKLIST ─────────────────────────────── -->
                <com.example.samvaad.ui.components.GlassmorphismContainer
                    android:id="@+id/card_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/card_background"
                    android:padding="22dp"
                    android:elevation="12dp"
                    app:layout_constraintTop_toBottomOf="@id/view_camera_placeholder">

                    <!-- Camera toggle row -->
                    <TextView
                        android:id="@+id/tv_camera_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Video + Audio"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switch_camera"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/switch_camera" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_camera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/teal_accent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Chaos toggle row -->
                    <TextView
                        android:id="@+id/tv_chaos_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Heartbeat Chaos Engine"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switch_chaos"
                        app:layout_constraintTop_toBottomOf="@id/switch_camera"
                        app:layout_constraintBottom_toBottomOf="@id/switch_chaos" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_chaos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/status_orange"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/switch_camera"
                        android:layout_marginTop="16dp" />

                    <!-- Divider -->
                    <View
                        android:id="@+id/divider_checklist"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"
                        android:background="#22FFFFFF"
                        app:layout_constraintTop_toBottomOf="@id/switch_chaos" />

                    <!-- CHECKLIST: Mic -->
                    <TextView
                        android:id="@+id/tv_check_mic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○  Microphone Verified"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/divider_checklist"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- CHECKLIST: Camera -->
                    <TextView
                        android:id="@+id/tv_check_camera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○  Camera Feed Verified"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_check_mic"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- CHECKLIST: Face -->
                    <TextView
                        android:id="@+id/tv_check_face"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○  User Detected in Frame"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_check_camera"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Golden Angle Check -->
                    <TextView
                        android:id="@+id/tv_check_orientation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○  Adjust phone angle (70°-85°)"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_check_face"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ProgressBar
                        android:id="@+id/pb_mic_amplitude"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="24dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/progress_teal"
                        app:layout_constraintTop_toBottomOf="@id/tv_check_orientation" />

                </com.example.samvaad.ui.components.GlassmorphismContainer>



                <!-- Orientation Warning -->
                <TextView
                    android:id="@+id/tv_orientation_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Adjust phone angle (70°-85°) for optimal AI visibility."
                    android:textColor="@color/status_orange"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/card_settings" />

                <!-- ── BEGIN BUTTON ──────────────────────────────── -->
                <com.example.samvaad.ui.components.LlmCustomButton
                    android:id="@+id/btn_begin_scenario"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="28dp"
                    android:text="Begin Scenario"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:elevation="12dp"
                    app:backgroundTint="@color/primary_purple"
                    app:cornerRadius="20dp"
                    app:icon="@android:drawable/ic_media_play"
                    app:iconGravity="textStart"
                    app:iconTint="@color/white"
                    app:layout_constraintTop_toBottomOf="@id/tv_orientation_warning" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ─────────────────────────────────────────────────────
             PHASE 2: FULL-SCREEN SIMULATOR (Immersive)
             ───────────────────────────────────────────────────── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <FrameLayout
                android:id="@+id/fl_question_progress"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="110dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.mikhaellopez.circularprogressbar.CircularProgressBar
                    android:id="@+id/cpb_question_progress"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cpb_background_progressbar_color="#1AFFFFFF"
                    app:cpb_background_progressbar_width="4dp"
                    app:cpb_progress_direction="to_right"
                    app:cpb_progressbar_color="@color/primary_purple"
                    app:cpb_progressbar_width="4dp"
                    app:cpb_round_border="true" />

                <TextView
                    android:id="@+id/tv_question_index_small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="1/6"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Metadata label -->
            <TextView
                android:id="@+id/tv_question_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="QUESTION"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toEndOf="@id/fl_question_progress"
                app:layout_constraintTop_toTopOf="@id/fl_question_progress"
                app:layout_constraintBottom_toBottomOf="@id/fl_question_progress" />

            <!-- Session timer -->
            <TextView
                android:id="@+id/tv_session_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="110dp"
                android:text="00:00"
                android:textColor="@color/teal_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- THE VAULT CARD — centered question display -->
            <com.example.samvaad.ui.components.GlassmorphismContainer
                android:id="@+id/card_question_vault"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/card_background"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingBottom="12dp"
                android:paddingTop="110dp"
                android:elevation="16dp"
                app:layout_constraintBottom_toTopOf="@id/ll_telemetry_indicators"
                app:layout_constraintTop_toBottomOf="@id/fl_question_progress">

                <!-- AI Speaking visualizer -->
                <LinearLayout
                    android:id="@+id/ll_sound_wave"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    
                    <View android:layout_width="3dp" android:layout_height="8dp" android:layout_margin="1.5dp" android:background="@color/primary_purple" />
                    <View android:layout_width="3dp" android:layout_height="18dp" android:layout_margin="1.5dp" android:background="@color/primary_purple" />
                    <View android:layout_width="3dp" android:layout_height="14dp" android:layout_margin="1.5dp" android:background="@color/primary_purple" />
                    <View android:layout_width="3dp" android:layout_height="22dp" android:layout_margin="1.5dp" android:background="@color/primary_purple" />
                    <View android:layout_width="3dp" android:layout_height="12dp" android:layout_margin="1.5dp" android:background="@color/primary_purple" />
                </LinearLayout>

                <!-- AI Speaking indicator -->
                <TextView
                    android:id="@+id/tv_ai_speaking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Interviewer is speaking..."
                    android:textColor="@color/primary_purple"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ll_sound_wave" />

                <!-- The actual question (now scrollable) -->
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/scroll_question"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"
                    android:fadeScrollbars="false"
                    app:layout_constraintTop_toBottomOf="@id/tv_ai_speaking"
                    app:layout_constraintBottom_toTopOf="@id/tv_silence_hint">

                    <TextView
                        android:id="@+id/tv_question_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:lineSpacingExtra="6dp"
                        android:text="Tell me about yourself and your journey so far."
                        android:textColor="@color/text_primary"
                        android:textSize="21sp"
                        android:textStyle="bold" />
                </androidx.core.widget.NestedScrollView>

                <!-- Silence detector hint (Pinned to bottom of vault) -->
                <TextView
                    android:id="@+id/tv_silence_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="⏳  Listening for your response..."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </com.example.samvaad.ui.components.GlassmorphismContainer>

            <!-- ── BREATHING ANIMATION OVERLAY ───────────────────── -->
            <FrameLayout
                android:id="@+id/fl_breathing"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/ll_telemetry_indicators"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/fl_question_progress">

                <View
                    android:id="@+id/ring_breath_outer"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:background="@drawable/breathing_ring"
                    android:layout_gravity="center" />

                <View
                    android:id="@+id/ring_breath_inner"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/breathing_ring"
                    android:layout_gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Breathe"
                    android:textColor="@color/teal_accent"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- ── TELEMETRY INDICATORS ROW (live metrics) ────────── -->
            <!-- ── TELEMETRY INDICATORS ROW (live metrics) ────────── -->
            <LinearLayout
                android:id="@+id/ll_telemetry_indicators"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toTopOf="@id/btn_next_question"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- WPM chip -->
                <TextView
                    android:id="@+id/tv_wpm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected_bg"
                    android:gravity="center"
                    android:paddingVertical="6dp"
                    android:text="-- WPM"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View android:layout_width="6dp" android:layout_height="1dp" />

                <!-- Silence count chip -->
                <TextView
                    android:id="@+id/tv_silence_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected_bg"
                    android:gravity="center"
                    android:paddingVertical="6dp"
                    android:text="0 Pauses"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View android:layout_width="6dp" android:layout_height="1dp" />

                <!-- Filler Words chip -->
                <TextView
                    android:id="@+id/tv_filler_words"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected_bg"
                    android:gravity="center"
                    android:paddingVertical="6dp"
                    android:text="0 'Umm's"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View android:layout_width="6dp" android:layout_height="1dp" />

                <!-- Mode chip -->
                <TextView
                    android:id="@+id/tv_chaos_indicator"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected_bg"
                    android:gravity="center"
                    android:paddingVertical="6dp"
                    android:text="Calm Mode"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── PRIMARY ACTION ROW ── -->
            <com.example.samvaad.ui.components.LlmCustomButton
                android:id="@+id/btn_next_question"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="Next Question ➔"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="invisible"
                app:backgroundTint="@color/primary_purple"
                app:cornerRadius="16dp"
                app:layout_constraintBottom_toTopOf="@id/ll_session_actions"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- ── ACTION BUTTONS ROW (Secondary) ────────── -->
            <LinearLayout
                android:id="@+id/ll_session_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintBottom_toTopOf="@id/pb_live_audio"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- Take a Breath (outlined teal) -->
                <com.example.samvaad.ui.components.LlmCustomButton
                    android:id="@+id/btn_breathe"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:text="Take a Breath"
                    android:textAllCaps="false"
                    android:textColor="@color/teal_accent"
                    android:textSize="12sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/teal_accent"
                    app:strokeWidth="1dp" />

                <!-- End Session (outlined red) -->
                <com.example.samvaad.ui.components.LlmCustomButton
                    android:id="@+id/btn_end_session"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="End Session"
                    android:textAllCaps="false"
                    android:textColor="@color/status_red"
                    android:textSize="12sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/status_red"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- ── LIVE AUDIO AMPLITUDE BAR (very bottom) ────────── -->
            <ProgressBar
                android:id="@+id/pb_live_audio"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginBottom="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/teal_accent"
                android:progressBackgroundTint="#1AFFFFFF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ─────────────────────────────────────────────────────
             PHASE 3: POST-SESSION ANALYTICS (Results)
             ───────────────────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/layout_session_results"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <com.example.samvaad.ui.components.GlassmorphismContainer
                    android:id="@+id/card_results_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="56dp"
                    android:background="@drawable/card_background"
                    android:padding="26dp"
                    android:elevation="12dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tv_results_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Session Complete"
                        android:textColor="@color/teal_accent"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_results_duration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Duration: 00:00"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        app:layout_constraintTop_toBottomOf="@id/tv_results_title" />

                    <TextView
                        android:id="@+id/tv_results_wpm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Pacing: -- WPM"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        app:layout_constraintTop_toBottomOf="@id/tv_results_duration" />

                </com.example.samvaad.ui.components.GlassmorphismContainer>

                <!-- Strengths Carousel Section -->
                <TextView
                    android:id="@+id/tv_strengths_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="🌟 Key Strengths"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/card_results_summary" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_strengths"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/tv_strengths_label" />

                <!-- Focus Areas Carousel Section -->
                <TextView
                    android:id="@+id/tv_focus_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="🎯 Focus Areas"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rv_strengths" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_focus_areas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/tv_focus_label" />

                <!-- Question Breakdown Section -->
                <TextView
                    android:id="@+id/tv_breakdown_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="💡 Question Breakdown"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rv_focus_areas" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_question_breakdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/tv_breakdown_label" />

                <!-- Legacy placeholders for backward compatible populating (hidden) -->
                <TextView android:id="@+id/tv_results_pauses" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
                <TextView android:id="@+id/tv_results_fillers" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />

                <com.example.samvaad.ui.components.LlmCustomButton
                    android:id="@+id/btn_return_home"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="40dp"
                    android:text="Return Home"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary_purple"
                    app:cornerRadius="18dp"
                    app:layout_constraintTop_toBottomOf="@id/rv_question_breakdown"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </ViewFlipper>

    <!-- ══════════════════════════════════════════════════════════
         FLOATING CAMERA CARD (PiP / Pre-Flight Mirror)
         ══════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_camera_container"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginTop="156dp"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="150dp"
        app:cardBackgroundColor="#1A1D36"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/view_finder"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
            
    </androidx.cardview.widget.CardView>

    <!-- Gesture Toast Badge Overlay -->
    <com.example.samvaad.ui.components.GlassmorphismContainer
        android:id="@+id/toast_gesture_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:background="@drawable/card_background"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView
            android:id="@+id/tv_gesture_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Action"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </com.example.samvaad.ui.components.GlassmorphismContainer>

    <!-- Next Question FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_next_question"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="110dp"
        android:text="Next →"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="@color/primary_purple"
        app:icon="@android:drawable/ic_media_next"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
