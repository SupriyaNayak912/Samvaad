<?xml version="1.0" encoding="utf-8"?>
<!-- Horizontal scenario card for Home screen "Recommended for You" -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:background="@drawable/card_scenario_h"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Category chip -->
    <TextView
        android:id="@+id/tv_category_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/chip_unselected_bg"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="HR"
        android:textColor="@color/teal_accent"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_scenario_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Tell me about yourself"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_category_chip" />

    <!-- Difficulty badge -->
    <TextView
        android:id="@+id/tv_difficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/badge_beginner"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="Beginner"
        android:textColor="@color/teal_accent"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_scenario_title" />

    <!-- Arrow -->
    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@android:drawable/ic_media_play"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/primary_purple" />

</androidx.constraintlayout.widget.ConstraintLayout>
