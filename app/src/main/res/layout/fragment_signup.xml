<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <!-- Glow rings -->
        <View
            android:id="@+id/ring_outer"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/glow_ring"
            android:alpha="0.35"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/logo_glow_bg"
            android:padding="13dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:elevation="8dp"
            app:tint="@color/white"
            app:layout_constraintBottom_toBottomOf="@id/ring_outer"
            app:layout_constraintEnd_toEndOf="@id/ring_outer"
            app:layout_constraintStart_toStartOf="@id/ring_outer"
            app:layout_constraintTop_toTopOf="@id/ring_outer" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Create Account"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ring_outer" />

        <TextView
            android:id="@+id/tv_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Start your communication journey"
            android:textColor="@color/teal_accent"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <!-- Sign Up Card -->
        <com.example.samvaad.ui.components.GlassmorphismContainer
            android:id="@+id/card_signup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:elevation="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_tagline">

            <!-- Teal accent line -->
            <View
                android:id="@+id/divider_accent"
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:layout_marginBottom="20dp"
                android:background="@color/teal_accent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Full Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_name"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Full Name"
                android:textColorHint="@color/text_secondary"
                app:boxStrokeColor="@color/primary_purple"
                app:boxStrokeWidth="1.5dp"
                app:boxBackgroundColor="@color/input_surface"
                app:hintTextColor="@color/text_secondary"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                app:startIconTint="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@id/divider_accent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_email"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Email Address"
                android:textColorHint="@color/text_secondary"
                app:boxStrokeColor="@color/primary_purple"
                app:boxStrokeWidth="1.5dp"
                app:boxBackgroundColor="@color/input_surface"
                app:hintTextColor="@color/text_secondary"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@id/til_name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Password"
                android:textColorHint="@color/text_secondary"
                app:boxStrokeColor="@color/primary_purple"
                app:boxStrokeWidth="1.5dp"
                app:boxBackgroundColor="@color/input_surface"
                app:hintTextColor="@color/text_secondary"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:startIconDrawable="@android:drawable/ic_lock_lock"
                app:startIconTint="@color/text_secondary"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@id/til_email">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Sign Up Button -->
            <com.example.samvaad.ui.components.LlmCustomButton
                android:id="@+id/btn_signup"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:elevation="6dp"
                app:backgroundTint="@color/primary_purple"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@id/til_password" />

            <!-- Google Sign Up -->
            <com.example.samvaad.ui.components.LlmCustomButton
                android:id="@+id/btn_google_signup"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:text="Sign up with Google"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/google_btn_bg"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="textStart"
                app:iconTint="@color/white"
                app:layout_constraintTop_toBottomOf="@id/btn_signup" />

            <!-- Already have account -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_google_signup">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account?  "
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textColor="#B388FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </com.example.samvaad.ui.components.GlassmorphismContainer>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="By continuing, you agree to our Terms of Service\nand Privacy Policy"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:alpha="0.7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_signup" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>