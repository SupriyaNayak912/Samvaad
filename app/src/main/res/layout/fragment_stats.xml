<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_done_stats">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Performance Analytics"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:gravity="center" />

            <!-- Circular Progress Bar -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="24dp">
                
                <com.mikhaellopez.circularprogressbar.CircularProgressBar
                    android:id="@+id/progress_global_score"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    app:cpb_background_progressbar_color="#1AFFFFFF"
                    app:cpb_background_progressbar_width="16dp"
                    app:cpb_progressbar_color="@color/teal_accent"
                    app:cpb_progressbar_width="16dp"
                    app:cpb_round_border="true" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <TextView
                        android:id="@+id/tv_global_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/text_primary"
                        android:textSize="48sp"
                        android:textStyle="bold" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pro-Score"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Insight Card -->
            <com.example.samvaad.ui.components.GlassmorphismContainer
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:elevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/chip_unselected_bg"
                        android:gravity="center"
                        android:text="💡"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tv_insight_tip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Analyzing your performance..."
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="4dp"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.example.samvaad.ui.components.GlassmorphismContainer>

            <!-- Mini Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:baselineAligned="false">

                <!-- Pace -->
                <com.example.samvaad.ui.components.GlassmorphismContainer
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:padding="12dp"
                    android:background="@drawable/card_background">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pace"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_score_pace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--%"
                            android:textColor="@color/primary_purple"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.example.samvaad.ui.components.GlassmorphismContainer>

                <!-- Resilience -->
                <com.example.samvaad.ui.components.GlassmorphismContainer
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:padding="12dp"
                    android:background="@drawable/card_background">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resilience"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_score_resilience"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--%"
                            android:textColor="@color/primary_purple"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.example.samvaad.ui.components.GlassmorphismContainer>

                <!-- Presence -->
                <com.example.samvaad.ui.components.GlassmorphismContainer
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:padding="12dp"
                    android:background="@drawable/card_background">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Presence"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_score_presence"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--%"
                            android:textColor="@color/primary_purple"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.example.samvaad.ui.components.GlassmorphismContainer>
            </LinearLayout>

            <!-- Line Chart (Volume) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Volume Timeline"
                android:textColor="@color/teal_accent"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp" />

            <com.example.samvaad.ui.components.GlassmorphismContainer
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:elevation="8dp">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_volume"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </com.example.samvaad.ui.components.GlassmorphismContainer>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Done Button -->
    <com.example.samvaad.ui.components.LlmCustomButton
        android:id="@+id/btn_done_stats"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:text="Continue to Dashboard"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/primary_purple"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>