## ─────────────────────────────────────────────────────────────────────────────
## local.properties.example
## This file IS committed to Git. It is a template only — no real secrets here.
##
## SETUP INSTRUCTIONS FOR ALL DEVELOPERS:
##   1. Copy this file and rename it to: local.properties
##   2. Fill in your own values below.
##   3. Never commit local.properties (it is already in .gitignore).
## ─────────────────────────────────────────────────────────────────────────────

## Android SDK path — update to match your machine
sdk.dir=/Users/YOUR_USERNAME/Library/Android/sdk

## Java Home (optional — only needed if you hit a jlink build error)
## Point this to a full JDK 21 on your machine, e.g.:
## org.gradle.java.home=/opt/homebrew/Cellar/openjdk@21/21.0.10/libexec/openjdk.jdk/Contents/Home

## Gemini API Key — get your free key at: https://aistudio.google.com
## Takes 2 minutes, no credit card required.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
