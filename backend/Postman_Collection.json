    {
      "name": "Scenarios",
      "item": [
        {
          "name": "Get All Scenarios",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/scenarios?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["scenarios"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "category",
                  "value": "Behavioral",
                  "disabled": true
                },
                {
                  "key": "difficulty",
                  "value": "Easy",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Random Scenario",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/scenarios/random",
              "host": ["{{base_url}}"],
              "path": ["scenarios", "random"]
            }
          }
        },
        {
          "name": "Get Scenario by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/scenarios/1",
              "host": ["{{base_url}}"],
              "path": ["scenarios", "1"]
            }
          }
        },
        {
          "name": "Create Scenario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Describe your biggest achievement\",\n  \"description\": \"Tell us about your proudest professional accomplishment\",\n  \"category\": \"Behavioral\",\n  \"difficulty\": \"Hard\",\n  \"duration_seconds\": 180,\n  \"tips\": \"Use the STAR method for structured response\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/scenarios",
              "host": ["{{base_url}}"],
              "path": ["scenarios"]
            }
          }
        }
      ]
    },
