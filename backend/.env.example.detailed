# ======= SERVER CONFIGURATION =======
PORT=8000
NODE_ENV=development

# ======= JWT (JSON Web Token) =======
# This is used to create login tokens
# Make it long and random for security
# You can generate one here: https://www.random.org/strings/
JWT_SECRET=Kx9$mP2#nL@qR7vW4bZ8yC5xF1aD3gH6jT0sN4uM9kP2wL5qR8tU1vX4yA7bC0dE3
JWT_EXPIRY=7d

# ======= FIREBASE CONFIGURATION =======
# Get these from Firebase Console
# 1. Go to https://console.firebase.google.com
# 2. Click Settings (gear icon)
# 3. Go to "Service Accounts" tab
# 4. Click "Generate New Private Key"
# 5. Copy values from the downloaded JSON file

# Your Firebase project ID
# Find in Firebase Console: Project Settings → General
FIREBASE_PROJECT_ID=samvaad-app-12345

# Your private key from Firebase
# Copy the entire "private_key" value from the JSON
# Keep the \n characters as-is
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC7VJTUt9Us8cKj\nMzEfYyjiWA4/4OwvjTFnPZVxVBGp+JDKq2I6MHpHhpHH5xXNCL8YZXoQW1wKyqfT\nB1xbfHc4eOQ3K2gkQxwD/C4w3bLI5YoLoLZ5HMVQ/4iYCXBzMx3Q/Fo3D8o/CQ3S\nYMVUyDH7J0zCGZ/CHMVhEPZ7F1Kq1nt3dBXf7lP2YXiT5mFzH8K7WYHuCW0C3Mto\nJ2vNHBEZQpgJ7lEP7fYvLI0KH5KGRVFxOF3Z7JHcC2gHYM5lR8ZFQJpKJPK4q0mY\nJzH8/M8UqHV4xNgYhVWJQ1Z9xKz8cQE0JNnNr5YwPqHqHvT2B7s7Y0V8JnEVQfKY\nJHQhK2I7AgMBAAECggEAF8bw4...more...private...key...content...more...content=\n-----END PRIVATE KEY-----\n"

# Your Firebase client email
# Copy the "client_email" value from the JSON
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xyzab@samvaad-app-12345.iam.gserviceaccount.com

